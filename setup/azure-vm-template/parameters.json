
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "westus2"
    },
    "networkInterfaceName": {
      "value": "devsecops-cloud801-wus2"
    },
    "enableAcceleratedNetworking": {
      "value": true
    },
    "networkSecurityGroupName": {
      "value": "devsecops-cloud-nsg-wus2"
    },
    "networkSecurityGroupRules": {
      "value": [
        {
          "name": "allow-all",
          "properties": {
            "priority": 100,
            "protocol": "*",
            "access": "Allow",
            "direction": "Inbound",
            "sourceAddressPrefix": "*",
            "sourcePortRange": "*",
            "destinationAddressPrefix": "*",
            "destinationPortRange": "*"
          }
        },
        {
          "name": "default-allow-ssh",
          "properties": {
            "priority": 1000,
            "protocol": "TCP",
            "access": "Allow",
            "direction": "Inbound",
            "sourceAddressPrefix": "*",
            "sourcePortRange": "*",
            "destinationAddressPrefix": "*",
            "destinationPortRange": "22"
          }
        }
      ]
    },
    "subnetName": {
      "value": "default"
    },
    "virtualNetworkName": {
      "value": "devsecops-cloud-vnet-wus2"
    },
    "addressPrefixes": {
      "value": [
        "10.0.0.0/16"
      ]
    },
    "subnets": {
      "value": [
        {
          "name": "default",
          "properties": {
            "addressPrefix": "10.0.0.0/24"
          }
        }
      ]
    },
    "publicIpAddressName": {
      "value": "devsecops-cloud-ip-wus2"
    },
    "publicIpAddressType": {
      "value": "Static"
    },
    "publicIpAddressSku": {
      "value": "Standard"
    },
    "virtualMachineName": {
      "value": "devsecops-cloud-wus2"
    },
    "virtualMachineComputerName": {
      "value": "devsecops-cloud-wus2"
    },
    "virtualMachineRG": {
      "value": "Devsecops-Group"
    },
    "osDiskType": {
      "value": "StandardSSD_LRS"
    },
    "dataDisks": {
      "value": [
        {
          "lun": 0,
          "createOption": "Empty",
          "diskSizeGB": 512
        }
      ]
    },
    "virtualMachineSize": {
      "value": "Standard_B2s_v2"
    },
    "adminUsername": {
      "value": "devsecops"
    },
    "adminPassword": {
      "value": null
    }
  }
}
